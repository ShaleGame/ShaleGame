[sub_resource type="Resource" id="Resource_d20wu"]
script = ExtResource("9_d20wu")
Speaker = "Old Sign"
Text = "This is a save point. These can be used to store your progress as you advance through the Chasm. "
Portrait = null
metadata/_custom_type_script = "uid://dag8a1mnv4sxx"

[sub_resource type="Resource" id="Resource_k6bcf"]
script = ExtResource("9_d20wu")
Speaker = "Old Sign"
Text = "Save points allow you to unconsciously turn back time to shift the world line in a more favorable direction."
Portrait = null
metadata/_custom_type_script = "uid://dag8a1mnv4sxx"

[sub_resource type="Resource" id="Resource_f7vin"]
script = ExtResource("9_d20wu")
Speaker = "Old Sign"
Text = "Having turned back time, you may have to fight some old foes, but some only show up until defeated once."
Portrait = null
metadata/_custom_type_script = "uid://dag8a1mnv4sxx"

[sub_resource type="Resource" id="Resource_78bik"]
script = ExtResource("9_d20wu")
Speaker = "Old Sign"
Text = "When you activate a save point, an Aether aura also heals any injuries, which feels quite refreshing!"
Portrait = null
metadata/_custom_type_script = "uid://dag8a1mnv4sxx"

[sub_resource type="Resource" id="Resource_i26st"]
script = ExtResource("10_78bik")
Frames = Array[Object]([SubResource("Resource_d20wu"), SubResource("Resource_k6bcf"), SubResource("Resource_f7vin"), SubResource("Resource_78bik")])
metadata/_custom_type_script = "uid://dklttlk8uwht5"

[sub_resource type="Resource" id="Resource_7posj"]
script = ExtResource("9_d20wu")
Speaker = "Messily Scrawled Note"
Text = "Talk about rotten luck... Our little test subject from the Heap escaped, and I trip down a hole looking for her!"
Portrait = Array[Texture2D]([])
metadata/_custom_type_script = "uid://dag8a1mnv4sxx"

[sub_resource type="Resource" id="Resource_ytbfb"]
script = ExtResource("9_d20wu")
Speaker = "Messily Scrawled Note"
Text = "My leg's broken, probably not going to have anyone find me before one of those Scuttlers gets me. Great."
Portrait = null
metadata/_custom_type_script = "uid://dag8a1mnv4sxx"

[sub_resource type="Resource" id="Resource_uvwob"]
script = ExtResource("9_d20wu")
Speaker = "Messily Scrawled Note"
Text = "That blasted lab rat... I think her name was \"Shale\" or something... she's somehow able to duplicate herself."
Portrait = null
metadata/_custom_type_script = "uid://dag8a1mnv4sxx"

[sub_resource type="Resource" id="Resource_0cjrq"]
script = ExtResource("9_d20wu")
Speaker = "Messily Scrawled Note"
Text = "Some sort of Aether mutation. I think. But like, think mitosis. The cells get pushed apart. It's like that but faster."
Portrait = null
metadata/_custom_type_script = "uid://dag8a1mnv4sxx"

[sub_resource type="Resource" id="Resource_bwbgm"]
script = ExtResource("9_d20wu")
Speaker = "Messily Scrawled Note"
Text = "Apparently, according to the security footage, she figured out how to use the force of splitting apart as propulsion!"
Portrait = null
metadata/_custom_type_script = "uid://dag8a1mnv4sxx"

[sub_resource type="Resource" id="Resource_rb0eo"]
script = ExtResource("9_d20wu")
Speaker = "Messily Scrawled Note"
Text = "She jumped into the air, started splitting, and in a split second, one of her was in the cage and the other went flying!"
Portrait = null
metadata/_custom_type_script = "uid://dag8a1mnv4sxx"

[sub_resource type="Resource" id="Resource_4hfqt"]
script = ExtResource("9_d20wu")
Speaker = "Messily Scrawled Note"
Text = "... I wish I could fly..."
Portrait = null
metadata/_custom_type_script = "uid://dag8a1mnv4sxx"

[sub_resource type="Resource" id="Resource_h3wuc"]
script = ExtResource("10_78bik")
Frames = Array[Object]([SubResource("Resource_7posj"), SubResource("Resource_ytbfb"), SubResource("Resource_uvwob"), SubResource("Resource_0cjrq"), SubResource("Resource_bwbgm"), SubResource("Resource_rb0eo"), SubResource("Resource_4hfqt")])
metadata/_custom_type_script = "uid://dklttlk8uwht5"

